EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Native Google Maps (Maps SDK for iOS + Android). Rebuild app after changing.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-native-key
# For push notifications (get from https://expo.dev → Your Project → Project Settings)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
